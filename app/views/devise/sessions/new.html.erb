<% content_for :title, "管理者ログイン" %>

<div class="login-wrapper">
  <div class="login-card">
    <h1 class="login-title">管理者ログイン</h1>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-group">
        <%= f.label :email, "メールアドレス" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
      </div>

      <div class="form-group remember">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, "ログイン状態を保持する" %>
      </div>

      <%= f.submit "ログイン", class: "btn-submit" %>
    <% end %>
  </div>
</div>

<style>
  body {
    background: #f5f5f5;
    margin: 0;
    font-family: sans-serif;
  }
  .login-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
  }
  .login-card {
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.1);
    padding: 48px 40px;
    width: 100%;
    max-width: 400px;
  }
  .login-title {
    font-size: 1.4rem;
    text-align: center;
    margin: 0 0 32px;
    color: #333;
  }
  .form-group {
    margin-bottom: 20px;
  }
  .form-group label {
    display: block;
    font-size: 0.875rem;
    color: #555;
    margin-bottom: 6px;
  }
  .form-input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 1rem;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }
  .form-input:focus {
    outline: none;
    border-color: #4a90e2;
  }
  .form-group.remember {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: #555;
  }
  .form-group.remember label {
    margin: 0;
  }
  .btn-submit {
    width: 100%;
    padding: 12px;
    background: #4a90e2;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    cursor: pointer;
    margin-top: 8px;
  }
  .btn-submit:hover {
    background: #357abd;
  }
</style>
